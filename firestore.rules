rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }
    function isProvider() {
      return isSignedIn() && request.auth.token.role == 'provider';
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function validScore(value) {
      return value is int && value >= 1 && value <= 5;
    }
    function validWorkerCriteria(criteria) {
      return (!("punctuality" in criteria) || validScore(criteria.punctuality)) &&
        (!("quality" in criteria) || validScore(criteria.quality)) &&
        (!("behavior" in criteria) || validScore(criteria.behavior)) &&
        (!("cleanliness" in criteria) || validScore(criteria.cleanliness)) &&
        (!("valueForMoney" in criteria) || validScore(criteria.valueForMoney));
    }
    function validCustomerCriteria(criteria) {
      return (
        (!("behavior" in criteria) || validScore(criteria.behavior)) &&
        (!("customerBehavior" in criteria) || validScore(criteria.customerBehavior)) &&
        (!("paymentPromptness" in criteria) || validScore(criteria.paymentPromptness)) &&
        (!("accessibility" in criteria) || validScore(criteria.accessibility)) &&
        (!("communication" in criteria) || validScore(criteria.communication))
      );
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      match /favorites/{workerId} {
        allow read, write: if isOwner(userId);
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /customers/{customerId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == customerId || isAdmin()
      );
    }

    // ── Providers (workers) ───────────────────────────────────────────────────
    match /providers/{providerId} {
      // Customers can read verified providers for discovery
      allow read: if isOwner(providerId) || isAdmin();
      // Provider can update their own doc; admin has full access
      allow write: if isOwner(providerId) || isAdmin();
    }

    match /workers/{workerId} {
      allow read: if isSignedIn() && request.auth.uid == workerId;
      allow write: if isSignedIn() && request.auth.uid == workerId;
    }

    // ── Bookings ──────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.customerId ||
        request.auth.uid == resource.data.providerId ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.customerId &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          request.auth.uid == resource.data.providerId &&
          resource.data.status == 'pending' &&
          request.resource.data.status in ['confirmed', 'cancelled']
        ) ||
        (
          isSignedIn() &&
          request.auth.uid == resource.data.customerId &&
          resource.data.status in ['pending', 'confirmed'] &&
          request.resource.data.status == 'cancelled'
        );
      allow delete: if isAdmin();

      // Disputes as sub-collection
      match /disputes/{disputeId} {
        allow read: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId ||
          request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.providerId ||
          isAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isAdmin();
      }
    }

    // ── Job Requests (provider receives) ──────────────────────────────────────
    match /jobRequests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.workerId ||
        request.auth.uid == resource.data.customerId ||
        isAdmin()
      );
      // Created by server (API route) — clients cannot create directly
      allow create: if isAdmin();
      // Provider can update status (accept/decline)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.workerId || isAdmin()
      );
    }

    // ── Worker Jobs (active jobs on provider side) ────────────────────────────
    match /workerJobs/{jobId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.workerId ||
        request.auth.uid == resource.data.customerId ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.workerId;
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == resource.data.workerId &&
        request.resource.data.status in ['accepted', 'on_way', 'arrived', 'working'] &&
        !(request.resource.data.status == 'completed') &&
        !(request.resource.data.status == 'cancelled')
      );
    }

    // ── Worker Earnings ───────────────────────────────────────────────────────
    match /workerEarnings/{earningId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.workerId || isAdmin()
      );
      // Written by Cloud Function / server only — no direct client writes
      allow write: if isAdmin();
    }

    // ── Withdrawal Requests ───────────────────────────────────────────────────
    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.workerId || isAdmin()
      );
      allow create: if isProvider() &&
        request.auth.uid == request.resource.data.workerId &&
        request.resource.data.amount >= 500;
      allow update: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.workerId || isAdmin()
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.workerId &&
        request.resource.data.amount >= 500;
      allow update: if isAdmin();
    }

    // ── Payments (Razorpay) ───────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.customerId ||
        request.auth.uid == resource.data.workerId ||
        isAdmin()
      );
      // Only written by API routes (server) — no direct client writes
      allow write: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      // Written inside completeBooking transaction — matches booking.ts
      allow write: if isSignedIn();
    }

    // ── Ratings ───────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.raterId == request.auth.uid
        && ratingId == request.resource.data.bookingId + '_' + request.auth.uid
        && request.resource.data.status == 'submitted'
        && request.resource.data.overallRating is int
        && validScore(request.resource.data.overallRating)
        && request.resource.data.reviewText is string
        && request.resource.data.reviewText.size() <= 2000
        && request.resource.data.tags is list
        && request.resource.data.bookingId is string
        && request.resource.data.ratedId is string
        && request.resource.data.raterType is string
        && request.resource.data.ratedType is string
        && request.resource.data.raterType in ['customer', 'worker']
        && request.resource.data.ratedType in ['customer', 'worker']
        && exists(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId))
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'completed'
        && (
          (
            request.resource.data.raterType == 'customer' &&
            request.resource.data.ratedType == 'worker' &&
            request.resource.data.ratedId == get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.providerId &&
            request.resource.data.raterId == get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.customerId &&
            validWorkerCriteria(request.resource.data.criteriaRatings)
          ) || (
            request.resource.data.raterType == 'worker' &&
            request.resource.data.ratedType == 'customer' &&
            request.resource.data.ratedId == get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.customerId &&
            request.resource.data.raterId == get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.providerId &&
            validCustomerCriteria(request.resource.data.criteriaRatings)
          )
        )
        && !exists(/databases/$(database)/documents/ratings/$(ratingId));
      allow update, delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.recipientId ||
        request.auth.uid == resource.data.customerId ||
        isAdmin()
      );
      allow update: if isSignedIn() &&
        (
          request.auth.uid == resource.data.recipientId ||
          request.auth.uid == resource.data.customerId
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      // Created by server only
      allow create: if isAdmin();
    }

    // ── Disputes (top-level collection for admin) ─────────────────────────────
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.raisedById || isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // ── Platform Settings ─────────────────────────────────────────────────────
    match /platformSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Platform Balance ──────────────────────────────────────────────────────
    match /platformBalance/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Daily Stats ───────────────────────────────────────────────────────────
    match /dailyStats/{date} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Admin collection ──────────────────────────────────────────────────────
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Serviceable Pincodes ──────────────────────────────────────────────────
    match /serviceablePincodes/{pincode} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
